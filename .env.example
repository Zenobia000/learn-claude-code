# API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Model ID (required)
MODEL_ID=claude-sonnet-5

# Base URL (optional, for Anthropic-compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
#  Anthropic-compatible providers
#
#  Provider         MODEL_ID              SWE-bench  TB2     Base URL
#  ---------------  --------------------  ---------  ------  -------------------
#  Anthropic        claude-sonnet-5         -          -     (default)
#  MiniMax          MiniMax-M2.5          80.2%        -     see below
#  GLM (Zhipu)      glm-5                77.8%        -     see below
#  Kimi (Moonshot)  kimi-k2.5            76.8%        -     see below
#  DeepSeek         deepseek-chat        73.0%        -     see below
#                   (V3.2)
#
#  SWE-bench = SWE-bench Verified (Feb 2026)
#  TB2       = Terminal-Bench 2.0 (Feb 2026)
#  Anthropic default above tracks the current recommended model, so benchmark
#  values are intentionally not pinned here.
# =============================================================================

# ---- International ----

# MiniMax          https://www.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://z.ai
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)  https://platform.moonshot.ai
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# MODEL_ID=kimi-k2.5

# DeepSeek         https://platform.deepseek.com
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# ---- China mainland ----

# MiniMax          https://platform.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://open.bigmodel.cn
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)  https://platform.moonshot.cn
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# MODEL_ID=kimi-k2.5

# DeepSeek (no regional split, same endpoint globally)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# =============================================================================
#  Native US and European APIs (reference for provider-specific integrations)
#
#  The agents in this repository natively use the Anthropic SDK and read
#  ANTHROPIC_API_KEY, ANTHROPIC_BASE_URL, and MODEL_ID. Other provider variables
#  below require the corresponding provider SDK or adapter.
#
#  Model IDs checked against official provider docs in July 2026. Preview model
#  IDs and rolling aliases can change; re-check the provider docs when upgrading.
# =============================================================================

# ---- United States ----

# Anthropic (Claude)  https://console.anthropic.com/settings/keys
# Native provider used by this repository. Choose one MODEL_ID for your workload.
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# MODEL_ID=claude-fable-5       # Most capable for long-running agents
# MODEL_ID=claude-opus-4-8      # Complex agentic coding and enterprise work
# MODEL_ID=claude-sonnet-5      # Best balance of speed and intelligence

# OpenAI             https://platform.openai.com/api-keys
# Current production frontier model; use the Responses API for new integrations.
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-5.6

# Google Gemini      https://aistudio.google.com/apikey
# Gemini 3.1 Pro is the frontier reasoning preview; Gemini 3.5 Flash is stable.
# GEMINI_API_KEY=xxx
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_MODEL_ID=gemini-3.1-pro-preview
# GEMINI_MODEL_ID=gemini-3.5-flash

# xAI (Grok)         https://console.x.ai/
# XAI_API_KEY=xai-xxx
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL_ID=grok-4.5

# ---- Europe ----

# Mistral AI         https://console.mistral.ai/api-keys/
# MISTRAL_API_KEY=xxx
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL_ID=mistral-medium-3-5
